@model List<NOA_Library.Models.Books>

@{
    ViewData["Title"] = $"Books in Genre: {ViewData["Genre"]}";
}

<h1>Books in Genre: @ViewData["Genre"]</h1>

@if (!string.IsNullOrEmpty(ViewData["Message"] as string))
{
    <div class="alert alert-warning">
        @ViewData["Message"]
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Genre</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var books in Model)
            {
                <tr>
                    <td>@books.Title</td>
                    <td>@books.Author</td>
                    <td>
                        @foreach (var genre in books.Genre.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="badge bg-primary">@genre.Trim()</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@books.Id" class="btn btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}