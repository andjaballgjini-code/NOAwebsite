@using Microsoft.AspNetCore.Identity;
@inject SignInManager<Users> signInManager;

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

<ul class="navbar-nav ms-auto">
    @if (signInManager.IsSignedIn(User))

    {

        <li class="nav-item">
            <a class="nav-link button-link" asp-area="" asp-controller="Account" asp-action="Logout">LOGOUT</a>

        </li>

        <li>
            <img id="userAvatar" src="/images/icon2.jpg" alt="User Avatar">

        </li>

        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" href="/Books">ADMIN</a>
            </li>
        }
        else if (User.IsInRole("User"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="User" asp-action="Profile">User Profile</a>
            </li>

        }
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link button-link" asp-area="" asp-controller="Account" asp-action="Login">LOGIN</a>

        </li>
        <li class="nav-item">
            <a class="nav-link button-link" asp-area="" asp-controller="Account" asp-action="Register">REGISTER</a>

        </li>
    }

</ul>

